{
  "manifest_version": 3,
  "name": "YT Speed Save",
  "description": "Keeps your YouTube playback speed between videos and refreshes.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
