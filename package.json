{
  "name": "yt-control",
  "displayName": "YT Control",
  "version": "1.5.0",
  "description": "Remember your YouTube speed and add Bluetooth video sync delay.",
  "author": "Noah Becker",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "1.12.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "action": {
      "default_popup": "popup.html",
      "default_title": "YT Control"
    },
    "permissions": [
      "storage"
    ]
  }
}
